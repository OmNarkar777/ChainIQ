# Database
DATABASE_URL=postgresql+asyncpg://chainiq:chainiq@localhost:5432/chainiq
SYNC_DATABASE_URL=postgresql://chainiq:chainiq@localhost:5432/chainiq

# Groq API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Model store
MODEL_STORE_DIR=./model_store

# App
APP_ENV=development
LOG_LEVEL=INFO
