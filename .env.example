# =============================================================================
# ChainIQ — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# REQUIRED = must be set for full functionality
# OPTIONAL = has a working default; override only if needed
# =============================================================================


# -----------------------------------------------------------------------------
# Groq LLM  (executive report generation)
# -----------------------------------------------------------------------------
# REQUIRED for AI-generated reports.
# Without this the report step falls back to a template-based summary —
# all other features (forecasting, inventory, RAG) continue to work.
# Get a free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# OPTIONAL — which Groq model to use for report generation
GROQ_MODEL=llama-3.3-70b-versatile


# -----------------------------------------------------------------------------
# Storage paths  (relative to the project root / container WORKDIR)
# -----------------------------------------------------------------------------
# OPTIONAL — where ChromaDB persists the supplier-doc vector index
CHROMA_PERSIST_DIR=./chroma_db

# OPTIONAL — where the trained XGBoost model files are stored
MODEL_STORE_DIR=./model_store


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# OPTIONAL — "development" or "production"
APP_ENV=development

# OPTIONAL — log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# OPTIONAL — comma-separated list of allowed CORS origins.
# Use * during local development or when the frontend and API are on the
# same domain. In production, set this to your exact frontend URL(s):
#   CORS_ORIGINS=https://chainiq.vercel.app
#   CORS_ORIGINS=https://chainiq.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=*


# =============================================================================
# Frontend environment variables  (Vite / React)
# =============================================================================
# These are set on the FRONTEND build, not the backend.
# They are NOT read from this .env file by the FastAPI app.
#
# When deploying to Vercel, set these in the Vercel dashboard:
#   Project → Settings → Environment Variables
#
# When running locally, the Vite dev server proxies /api → localhost:8000
# automatically (see frontend/vite.config.js), so VITE_API_URL is not needed.
#
# VITE_API_URL=https://chainiq-api.onrender.com
#   ↑ Set this in Vercel/Netlify to point at your Render backend URL.
#   ↑ Leave commented out for local development and docker-compose.
